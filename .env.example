# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# .env.local ist in .gitignore — landet niemals im Repo.
#
# Die selben Werte musst du auch in den GitHub-Actions-Secrets setzen
# (Repo → Settings → Secrets and variables → Actions), damit der CI-Build
# sie zur Laufzeit kennt.

# Supabase-Projekt-URL — z.B. https://abc123def456.supabase.co
VITE_SUPABASE_URL=

# Supabase Anon-Key (aus dem Supabase-Dashboard → Project Settings → API)
# Das ist der PUBLIC-Anon-Key, kein Service-Role-Key.
VITE_SUPABASE_ANON_KEY=
